# Required — used to sign JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=

# Database credentials — defaults to user/password/flashcards if unset
# Generate a password with: openssl rand -hex 16
POSTGRES_USER=user
POSTGRES_PASSWORD=
POSTGRES_DB=flashcards

# S3 backups (prod only)
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2

# Judge0 (code execution engine)
JUDGE0_URL=http://judge0-server:2358
JUDGE0_SECRET_KEY_BASE=
JUDGE0_DB_USER=judge0
JUDGE0_DB_PASSWORD=
JUDGE0_DB_NAME=judge0
JUDGE0_AUTHN_TOKEN=
JUDGE0_AUTHZ_TOKEN=
