# Required — used to sign JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=

# Database credentials — defaults to user/password/flashcards if unset
# Generate a password with: openssl rand -hex 16
POSTGRES_USER=user
POSTGRES_PASSWORD=
POSTGRES_DB=flashcards

# S3 backups (prod only)
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
